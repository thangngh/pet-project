# Application
NODE_ENV=development
PORT=3001
API_PREFIX=api
CORS_ORIGINS=*

# JWT
JWT_SECRET=change-this-to-a-random-64-char-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=ddd_project
DB_SYNCHRONIZE=false
DB_LOGGING=false

# Rate Limit
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Feature Gates
FEATURE_RBAC=false
FEATURE_ABAC=false

# Logging
LOG_LEVEL=info
