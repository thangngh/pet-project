# Application
NODE_ENV=development
PORT=3001
API_PREFIX=api
CORS_ORIGINS=*

# JWT
JWT_SECRET=change-this-to-a-random-64-char-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=ddd_project
DB_SYNCHRONIZE=false
DB_LOGGING=false

# Database — Per Context (Docker Compose)
DB_AUTH_PORT=5432
DB_AUTH_DATABASE=ddd_auth
DB_AUTH_USERNAME=postgres
DB_AUTH_PASSWORD=postgres

DB_USER_PORT=5433
DB_USER_DATABASE=ddd_user
DB_USER_USERNAME=postgres
DB_USER_PASSWORD=postgres

DB_CATALOG_PORT=5434
DB_CATALOG_DATABASE=ddd_catalog
DB_CATALOG_USERNAME=postgres
DB_CATALOG_PASSWORD=postgres

# Rate Limit
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Feature Gates
FEATURE_RBAC=false
FEATURE_ABAC=false

# Logging
LOG_LEVEL=info
